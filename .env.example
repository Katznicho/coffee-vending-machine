APP_NAME="La Patisserie Express"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000:8000
APP_DEMO_QUICK_LOGIN=true
DEMO_LOGIN_EMAIL=admin@vendormachine.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vendor_machine
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database

CACHE_STORE=database

VENDING_VERIFY_SIGNATURE=true
VENDING_DEFAULT_CHANNEL_ID=36
VENDING_ORDER_EXPIRY_MINUTES=15
VENDING_SYNC_PENDING_PAYMENTS=true
VENDING_SYNC_PENDING_BATCH_SIZE=50
VENDING_SYNC_PENDING_SCHEDULE=everyMinute
VENDING_DEMO_SECRET_KEY=demo-secret-key-change-me

# Cellulant credentials are managed in Admin > Cellulant (/settings/cellulant)
